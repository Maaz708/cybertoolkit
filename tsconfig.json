{
    "compilerOptions": {
        "target": "ES2022", 
        "module": "ESNext", 
        "moduleResolution": "node",
        "jsx": "react-jsx", 
        "strict": true, 
        "esModuleInterop": true, 
        "skipLibCheck": true, 
        "forceConsistentCasingInFileNames": true, 
        "outDir": "./dist", 
        "rootDir": "./src", 
        "types": ["vite/client"]
    },
    "include": [
        "src/**/*" 
    ],
    "exclude": [
        "node_modules" 
    ]
}